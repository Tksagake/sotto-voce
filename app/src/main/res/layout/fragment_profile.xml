<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_dark">

    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:background="@color/accent_green"
        app:shapeAppearanceOverlay="@style/CornerSize50Percent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Siko_leer"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"
        android:text="Tier: Sotto Voce Exclusive"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/profile_edit_btn"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:textColor="@color/text_primary"
        app:strokeColor="@color/text_secondary"
        android:text="Edit Profile" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_mini_player"
        android:backgroundTint="@color/surface_dark"
        android:padding="16dp"
        android:layout_marginTop="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spotify Integration"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste your Spotify Developer Client ID and Secret to sync your liked songs and playlists bypassing the premium lock."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/profile_api_client_id"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_mini_player"
            android:backgroundTint="@color/surface_lighter"
            android:hint="Client ID"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/profile_api_secret"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_mini_player"
            android:backgroundTint="@color/surface_lighter"
            android:hint="Client Secret"
            android:inputType="textPassword"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/profile_sync_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/accent_green"
            android:textColor="@color/black"
            android:text="Sync Spotify Library"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground"
    tools2:ignore="ResAuto">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/track_image"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:background="@color/surface_dark"
        app:shapeAppearanceOverlay="@style/RoundedSquare"
        android:contentDescription="Album Art"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/track_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="God's Plan"
        app:layout_constraintStart_toEndOf="@id/track_image"
        app:layout_constraintEnd_toStartOf="@id/track_options_btn"
        app:layout_constraintTop_toTopOf="@id/track_image"
        app:layout_constraintBottom_toTopOf="@id/track_artist"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/track_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Drake"
        app:layout_constraintStart_toEndOf="@id/track_image"
        app:layout_constraintEnd_toStartOf="@id/track_options_btn"
        app:layout_constraintTop_toBottomOf="@id/track_title"
        app:layout_constraintBottom_toBottomOf="@id/track_image" />

    <ImageView
        android:id="@+id/track_options_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_more"
        app:tint="@color/text_secondary"
        android:contentDescription="Options Menu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>